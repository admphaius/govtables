# =============================================================
# GovTables — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no git.
# =============================================================

# -------------------------------------------------------------
# Supabase — obrigatório
# Encontre em: https://supabase.com/dashboard/project/<ref>/settings/api
# -------------------------------------------------------------

# URL pública do projeto (safe para expor no frontend)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Chave anon (safe para expor no frontend — limitada por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave service_role — NUNCA expor no frontend
# Usada apenas em: admin client, ETL routes, Edge Functions
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -------------------------------------------------------------
# OpenAI — obrigatório para busca semântica
# Encontre em: https://platform.openai.com/api-keys
# -------------------------------------------------------------

OPENAI_API_KEY=sk-proj-...

# -------------------------------------------------------------
# ETL — obrigatório para proteger as rotas de ingestão
# Gere com: openssl rand -hex 32
# -------------------------------------------------------------

ETL_SECRET=<string-aleatoria-longa>

# -------------------------------------------------------------
# Vercel — apenas para CI/CD (não precisa em .env.local)
# Configurar como secrets no repositório GitHub:
#   VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
# Encontre em: https://vercel.com/account/tokens
#              https://vercel.com/<team>/settings
# -------------------------------------------------------------

# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# -------------------------------------------------------------
# Supabase CLI — apenas para CI/CD (não precisa em .env.local)
# Configurar como secret no GitHub: SUPABASE_ACCESS_TOKEN
# Encontre em: https://supabase.com/dashboard/account/tokens
# -------------------------------------------------------------

# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=<project-ref>
